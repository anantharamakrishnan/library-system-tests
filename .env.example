# Copy this file to .env.dev / .env.qa / .env.prod and fill in real values.
# Never commit a file containing real credentials.

TEST_ENV=dev

BASE_URL=https://dev.library.internal
API_BASE_URL=https://api.dev.library.internal/v1

BROWSER=chromium
HEADLESS=true
SLOW_MO=0
RECORD_VIDEO=false
TRACE=false

ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change_me
STANDARD_USERNAME=user@example.com
STANDARD_PASSWORD=change_me
READONLY_USERNAME=readonly@example.com
READONLY_PASSWORD=change_me

TIMEOUT_NAVIGATION=45000
TIMEOUT_ELEMENT=15000
TIMEOUT_API=20000
