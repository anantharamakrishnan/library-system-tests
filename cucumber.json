{
  "default": {
    "paths": ["features/**/*.feature"],
    "require": ["src/**/*.ts", "src/config/cucumber.ts"],
    "publishQuiet": true,
    "failFast": false,
    "format": [
      "progress",
      "allure-cucumberjs/reporter"
    ],
    "formatOptions": {
      "resultsDir": "allure-results"
    },
    "parallel": 1
  }
}
